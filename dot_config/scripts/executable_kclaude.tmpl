#!/bin/bash

# ============================================
# Claude Wrapper - IP 校验启动脚本
# 用法: ./claude-wrapper.sh [claude 参数...]
# 配置: 修改 ALLOWED_IP 为你的目标 IP
# ============================================

ALLOWED_IP="107.175.140.21" # 通过环境变量或直接修改此默认值
TIMEOUT=5
{{ if eq .work_env "home" }}
# .work_env = home
PROXY_URL="http://192.168.124.200:7890"

{{ else if eq .work_env "bytedance_work"}}

# .work_env = bytedance_work
PROXY_URL="http://127.0.0.1:7890"

{{ end }}

echo "设置代理为 $PROXY_URL"
# 获取当前公网 IP
current_ip=$(
  env \
    https_proxy="$PROXY_URL" \
    http_proxy="$PROXY_URL" \
    HTTPS_PROXY="$PROXY_URL" \
    HTTP_PROXY="$PROXY_URL" \
    curl -s --max-time "$TIMEOUT" ipinfo.io/ip
)

if [[ -z "$current_ip" ]]; then
  echo "[ERROR] 无法获取当前公网 IP，请检查网络连接" >&2
  exit 1
fi

if [[ "$current_ip" != "$ALLOWED_IP" ]]; then
  echo "[BLOCKED] 当前 IP: $current_ip, 允许的 IP: $ALLOWED_IP" >&2
  echo "[BLOCKED] IP 不匹配，拒绝启动 Claude" >&2
  exit 1
fi

echo "[OK] IP 校验通过: $current_ip"
exec env \
  https_proxy="$PROXY_URL" \
  http_proxy="$PROXY_URL" \
  HTTPS_PROXY="$PROXY_URL" \
  HTTP_PROXY="$PROXY_URL" \
  claude "$@"
